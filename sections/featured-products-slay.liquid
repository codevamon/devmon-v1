<section class="featured-products-i">
  <div class="container-i-fix flex-column align-center gap-iii">
    
    <!-- HEADER DE SECCIÓN -->
    <div class="text-center flex-column gap-i">
      {% if section.settings.heading != blank %}
        <div class="subhe-xl" style="color: var(--color-wild-pulse);">
          <h2>{{ section.settings.heading }}</h2>
        </div>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="bo-m fw-bold" style="color: var(--color-wild-pulse);">
          {{ section.settings.subheading }}
        </div>
      {% endif %}
    </div>

    <!-- GRID DE PRODUCTOS (2 Columnas) -->
    <div class="flex-i space-between w-100">
      
      {% for i in (1..2) %}
        {% capture current_product_id %}product_{{ i }}{% endcapture %}
        {% assign prod = section.settings[current_product_id] %}

        <div class="w-12 w-lg-6 product-card-dual-i">
          {% if prod != blank %}
            
            <a href="{{ prod.url }}" class="product-card-link-i">
              
              <!-- ÁREA DE IMAGEN (Con Hover Marquee) -->
              <div class="product-card-media-i">
                
                <!-- Imagen Principal -->
                <img 
                  src="{{ prod.featured_image | image_url: width: 800 }}" 
                  alt="{{ prod.title | escape }}" 
                  class="media-main-i"
                  loading="lazy"
                  width="100%"
                  height="100%"
                >
                
                <!-- Imagen Hover (Si existe una segunda imagen) -->
                {% if prod.media[1] != blank %}
                  <img 
                    src="{{ prod.media[1] | image_url: width: 800 }}" 
                    alt="{{ prod.title | escape }} alternate view" 
                    class="media-hover-i"
                    loading="lazy"
                    width="100%"
                    height="100%"
                  >
                {% endif %}

                <!-- Marquee Animado (Add to bag) -->
                <div class="product-card-marquee-i" style="background-color: var(--color-wild-pulse); color: var(--color-white);">
                  <div class="marquee-track-i bo-s uppercase fw-bold">
                    <span>→ ADD TO BAG</span>
                    <span>→ ADD TO BAG</span>
                    <span>→ ADD TO BAG</span>
                    <span>→ ADD TO BAG</span>
                    <span>→ ADD TO BAG</span>
                  </div>
                </div>

              </div>

              <!-- ÁREA DE INFO -->
              <div class="product-card-info-i flex-column gap-i" style="margin-top: 1.5vw;">
                <div class="flex-i space-between align-start">
                  <h3 class="he-l fw-bold" style="color: var(--color-wild-pulse); margin: 0;">{{ prod.title }}</h3>
                  <span class="bo-m fw-bold" style="color: var(--color-wild-pulse);">{{ prod.price | money }}</span>
                </div>
                
                {% if prod.metafields.custom.short_description != blank %}
                  <div class="bo-s" style="color: var(--color-wild-pulse);">
                    {{ prod.metafields.custom.short_description }}
                  </div>
                {% else %}
                  <div class="bo-s" style="color: var(--color-wild-pulse); opacity: 0.8;">
                    {{ prod.description | strip_html | truncatewords: 20 }}
                  </div>
                {% endif %}
              </div>
            </a>

          {% else %}
            <!-- PLACEHOLDER (Si no hay producto seleccionado) -->
            <div style="width: 100%; height: 500px; background: #ddd; display: flex; align-items: center; justify-content: center;">
              Selecciona un producto {{ i }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
      
    </div>
  </div>
</section>

{% stylesheet %}

.featured-products-i {
  background-color:  var(--color-inner-glow);
  padding: var(--padding-section) 0;
}

.product-card-dual-i {
  position: relative;
  display: block;
}

.product-card-link-i {
  text-decoration: none;
  display: block;
  width: 100%;
}

.product-card-media-i {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background-color: #EAEAEA;
}

.media-main-i,
.media-hover-i {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.5s cubic-bezier(0.25, 1, 0.5, 1);
}

.media-hover-i {
  opacity: 0; 
}

.product-card-link-i:hover .media-main-i {
  opacity: 0;
}
.product-card-link-i:hover .media-hover-i {
  opacity: 1;
}

/* --- Marquee Animado --- */
.product-card-marquee-i {
  position: absolute;
  top: 0; 
  left: 0;
  width: 100%;
  padding: 1vw 0;
  overflow: hidden;
  white-space: nowrap;
  transform: translateY(-100%); 
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  z-index: 10;
}

/* Mostramos el marquee al hacer hover */
.product-card-link-i:hover .product-card-marquee-i {
  transform: translateY(0);
}

.marquee-track-i {
  display: inline-flex;
  gap: 2vw;
  padding-left: 2vw;
  animation: scroll-marquee 10s linear infinite;
}

.marquee-track-i span {
  display: inline-block;
}

@keyframes scroll-marquee {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* --- Layout Mobile --- */
@media (max-width: 992px) {
  .product-card-marquee-i {
    padding: 3vw 0;
  }
  .marquee-track-i {
    gap: 5vw;
  }
  .product-card-info-i {
    margin-top: 4vw !important;
  }
}
  
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Products Dual",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Your New Obsession Awaits"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Subscribe & Save + Free Welcome Gift"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Producto Izquierdo"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Producto Derecho"
    }
  ],
  "presets": [
    {
      "name": "Featured Products Dual (Slay)"
    }
  ]
}
{% endschema %}

