<section class="about-iii" id="AboutIII-{{ section.id }}">
  <div class="in-about-iii container-i">

    {% if section.blocks.size > 0 %}
      <div class="timeline-about-iii">
        <div class="track-about-iii">
          <div class="indicator-about-iii" aria-hidden="true">
            <span class="bo-xs fw-regular"></span>
          </div>

          {% for block in section.blocks %}
            <button
              class="item-timeline-about-iii{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-about-iii-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              <span class="line-before"></span>
              <span class="year bo-xs fw-regular">{{ block.settings.year }}</span>
              <span class="line-after"></span>
            </button>
          {% endfor %}
        </div>
      </div>

      <div class="splide about-iii-splide" aria-label="About timeline">
        <div class="splide__track">
          <ul class="splide__list">

            {% for block in section.blocks %}
              <li class="splide__slide">
                <article class="item-about-iii{% if forloop.first %} is-active{% endif %}">
                  {% if block.settings.title != blank %}
                    <div class="bo-s fw-bold">
                      <h3>{{ block.settings.title }}</h3>
                    </div>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="bo-xs fw-regular">
                      <p>{{ block.settings.text }}</p>
                    </div>
                  {% endif %}
                </article>
              </li>
            {% endfor %}

          </ul>
        </div>
      </div>
    {% endif %}

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('#AboutIII-{{ section.id }}');
    if (!section || typeof Splide === 'undefined') return;

    var splideEl = section.querySelector('.about-iii-splide');
    var track = section.querySelector('.track-about-iii');
    var indicator = section.querySelector('.indicator-about-iii');
    var indicatorText = indicator ? indicator.querySelector('span') : null;
    var timelineItems = Array.from(section.querySelectorAll('.item-timeline-about-iii'));
    var contentItems = Array.from(section.querySelectorAll('.item-about-iii'));

    if (!splideEl || !track || !indicator || !timelineItems.length) return;

    var splide = new Splide(splideEl, {
      type: 'slide',
      perPage: 4,
      perMove: 1,
      gap: '3vw',
      arrows: false,
      pagination: false,
      drag: true,
      speed: 650,
      breakpoints: {
        1200: {
          perPage: 3
        },
        991: {
          perPage: 2,
          gap: '5vw'
        },
        768: {
          perPage: 1,
          gap: '6vw'
        }
      }
    });

    function moveIndicator(index) {
      var item = timelineItems[index];
      if (!item) return;

      var trackRect = track.getBoundingClientRect();
      var itemRect = item.getBoundingClientRect();
      var year = item.querySelector('.year');

      var itemCenter = itemRect.left - trackRect.left + (itemRect.width / 2);
      var indicatorWidth = indicator.offsetWidth;
      var left = itemCenter - (indicatorWidth / 2);

      indicator.style.transform = 'translateX(' + left + 'px)';

      if (indicatorText && year) {
        indicatorText.textContent = year.textContent.trim();
      }

      timelineItems.forEach(function (el, i) {
        el.classList.toggle('is-active', i === index);
      });

      contentItems.forEach(function (el, i) {
        el.classList.toggle('is-active', i === index);
      });
    }

    timelineItems.forEach(function (item, index) {
      item.addEventListener('click', function () {
        splide.go(index);
      });
    });

    splide.on('mounted move moved resized updated', function () {
      moveIndicator(splide.index);
    });

    splide.mount();

    window.addEventListener('resize', function () {
      moveIndicator(splide.index);
    });
  });
</script>

{% schema %}
{
  "name": "About III",
  "settings": [],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline item",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2020"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Story Begins"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Your brand story goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About III",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "year": "2020",
            "title": "Our Story Begins",
            "text": "Your brand story goes here."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "year": "2021",
            "title": "Growing the Brand",
            "text": "Premium products crafted with care."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "year": "2022",
            "title": "New Chapter",
            "text": "Explore our collection."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "year": "2023",
            "title": "Looking Ahead",
            "text": "Customer experience remains our priority."
          }
        }
      ]
    }
  ]
}
{% endschema %}