<section class="superhero-i">
  <div class="in-superhero-i">

    <div class="flex">

      <div class="item-superhero item-superhero-1 w-12 w-lg-6">
        <div class="in-item-superhero-i">
          <div class="sidecontainer-i">

            {% if section.settings.heading != blank %}
              <div class="he-xxl fw-medium uppercase">
                <h1>{{ section.settings.heading }}</h1>
              </div>
            {% endif %}

            {% if section.settings.subheading != blank %}
              <div class="bo-m fw-regular">
                <p>{{ section.settings.subheading }}</p>
              </div>
            {% endif %}

            {% if section.settings.button_label != blank %}
              <a class="btn-i btn-tumeric withicon" href="{{ section.settings.button_url }}">
                <span class="btn-text">{{ section.settings.button_label }}</span>
                <span class="btn-icon"><i class="bi bi-chevron-right"></i></span>
              </a>
            {% endif %}

          </div>


        </div>

