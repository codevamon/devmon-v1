<section class="reviews-i">
  <div class="in-reviews-i">
    <div class="head-reviews-i container-i">
      {% if section.settings.eyebrow != blank %}
        <div class="bo-xs fw-regular">
          <p>{{ section.settings.eyebrow }}</p>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="he-l fw-regular">
          <h2>{{ section.settings.heading }}</h2>
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="body-reviews-i">
        <div class="splide reviews-splide-i" aria-label="{{ section.settings.heading | escape }}">
          <div class="splide__track">
            <ul class="splide__list">

              {% for block in section.blocks %}
                <li class="splide__slide" {{ block.shopify_attributes }}>
                  <div class="item-reviews-i">
                    <div class="in-item-reviews-i">

                      {% if block.settings.image != blank %}
                        <figure class="media-reviews-i">
                          {{ block.settings.image | image_url: width: 180 | image_tag: loading: 'lazy' }}
                        </figure>
                      {% endif %}

                      {% if block.settings.quote != blank %}
                        <div class="bo-l fw-medium">
                          <h3>“{{ block.settings.quote }}”</h3>
                        </div>
                      {% endif %}

                      {% if block.settings.text != blank %}
                        <div class="bo-s fw-regular">
                          <p>{{ block.settings.text }}</p>
                        </div>
                      {% endif %}

                      {% if block.settings.author != blank %}
                        <div class="bo-xs fw-medium">
                          <p>{{ block.settings.author }}</p>
                        </div>
                      {% endif %}

                    </div>
                  </div>
                </li>
              {% endfor %}

            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var el = document.querySelector('.reviews-i .reviews-splide-i');

    if (!el || typeof Splide === 'undefined') return;

    new Splide(el, {
      type: 'loop',
      perPage: 3,
      perMove: 1,
      gap: '5vw',
      arrows: false,
      pagination: false,
      drag: true,
      snap: true,
      autoplay: true,
      interval: 3500,
      speed: 850,
      pauseOnHover: false,
      pauseOnFocus: false,
      padding: {left: '5vw', right: '5vw'},
      breakpoints: {
        991: {
          perPage: 2,
          gap: '4vw'
        },
        768: {
          perPage: 1,
          gap: '6vw'
        }
      }
    }).mount();
  });
</script>

{% schema %}
{
  "name": "Reviews I",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Reviews"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "What People Say"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Small image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Great quality and fast delivery."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "This is a sample review. Replace with your customer feedback."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author label",
          "default": "Customer Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews I",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}